{
  "name": "ai-image-generator-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --include=dev --prefix frontend && npm install --include=dev --prefix backend",
    "install:all": "npm install && npm run postinstall",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build": "npm run build:frontend && npm run build:backend",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start": "NODE_ENV=production npm run start:backend"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^8.2.2"
  }
}
